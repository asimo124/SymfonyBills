# Copy to .env (and optionally .env.local). Do not commit real secrets.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_string
###< symfony/framework-bundle ###

# Docker MariaDB (compose.yaml always creates application user "app"; ignore MARIADB_USER for Docker DB).
MARIADB_DATABASE=asimo124_bills
MARIADB_PASSWORD=app_password_change_me
MARIADB_ROOT_PASSWORD=root_password_change_me

# Host "db"; user is always "app"; password must match MARIADB_PASSWORD; database = MARIADB_DATABASE.
DATABASE_URL="mysql://app:app_password_change_me@db:3306/asimo124_bills?serverVersion=10.11.14-MariaDB&charset=utf8mb4"
